# Bridge GAD Generator — environment variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Contact info (replaces hardcoded PII in UI) ───────────────────────────────
CONTACT_EMAIL=contact@example.com
CONTACT_PHONE=+91XXXXXXXXXX

# ── Telemetry (opt-in, default OFF) ──────────────────────────────────────────
BRIDGE_GAD_TELEMETRY=0

# ── ARQ / Redis (for async job queue) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=120
ARQ_KEEP_RESULT=3600

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
